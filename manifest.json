{
  "manifest_version": 3,
  "name": "OnPage CV",
  "version": "1.2.0",
  "description": "Highlight job descriptions and instantly generate tailored resume bullets and summaries right on the job page.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost/*",
    "https://onpagecv.on-forge.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/resume-tailor-logo.png",
      "48": "icons/resume-tailor-logo.png",
      "128": "icons/resume-tailor-logo.png"
    }
  },
  "icons": {
    "16": "icons/resume-tailor-logo.png",
    "48": "icons/resume-tailor-logo.png",
    "128": "icons/resume-tailor-logo.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["popup.html", "popup.css", "content.js", "popup-injector.js", "*.js", "*.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
